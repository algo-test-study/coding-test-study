class Solution {
    public int maxProfit(int[] prices) {
        int minPrice = prices[0];
        int maxProfit = 0;


        for (int i = 0; i < prices.length; i++) {
            int currentPrice = prices[i];
            
            maxProfit = Math.max(maxProfit, currentPrice - minPrice);
            minPrice = Math.min(minPrice, currentPrice);
        }

        return maxProfit;
    }
}
